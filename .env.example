FLASK_ENV=production
LOG_LEVEL=INFO
DATABASE_PATH=instance/monitoring.db

# Detection tuning
ERROR_KEYWORDS=ERROR,FAILED,TIMEOUT
REPEATED_FAILURE_THRESHOLD=3
REPEATED_FAILURE_WINDOW_SECONDS=300
HIGH_FREQUENCY_THRESHOLD=20
HIGH_FREQUENCY_WINDOW_SECONDS=60
ALERT_COOLDOWN_SECONDS=60

# Optional Slack alerting
SLACK_WEBHOOK_URL=

# Optional email alerting
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

